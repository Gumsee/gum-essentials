@PACKAGE_INIT@

include("@CMAKE_INSTALL_FULL_LIBDIR@/cmake/@CMAKE_PROJECT_NAME@/@CMAKE_PROJECT_NAME@Targets.cmake")

check_required_components(@CMAKE_PROJECT_NAME@)

set(GUMESSENTIALS_INCLUDE_DIRS   "@CMAKE_INSTALL_FULL_INCLUDEDIR@/@CMAKE_PROJECT_NAME@" )
find_library(GUMESSENTIALS_LIBRARIES NAMES @CMAKE_PROJECT_NAME@
    PATHS
    /usr/lib
    /usr/local/lib
)

set(GUMESSENTIALS_FOUND TRUE)
if(NOT GUMESSENTIALS_LIBRARIES)
    set(GUMESSENTIALS_FOUND FALSE)
endif()
